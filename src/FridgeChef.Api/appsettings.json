{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=fridgechef;Username=kirill;Include Error Detail=true"
  },
  "Jwt": {
    "Secret": "FridgeChefSuperSecretKeyThatIsAtLeast32BytesLong!!",
    "Issuer": "FridgeChef",
    "Audience": "FridgeChefApp",
    "ExpiryHours": 24
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5500",
      "http://127.0.0.1:5500"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information"
    }
  },
  "Pricing": {
    "AutoSync": false,
    "PuppeteerScraper": {
      "BaseUrl": "http://localhost:3333",
      "BatchSize": 20,
      "SingleTimeoutSeconds": 30,
      "BatchTimeoutSeconds": 300
    }
  }
}
